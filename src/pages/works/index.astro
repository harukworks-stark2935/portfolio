---
import PageTtl from "../../components/page-ttl.astro"
import TextLinkTop from "../../components/textLinkTop.astro"
import Layout from "../../layouts/Layout.astro"
---

<Layout>
  <PageTtl title="WORKS" />
  <ul class="works__nav">
    <li><button class="works__item" type="button" disabled>自主制作</button></li>
    <li><button class="works__item" type="button" disabled>HTML</button></li>
    <li><button class="works__item" type="button" disabled>Vue.js/Nuxt.js</button></li>
    <li><button class="works__item" type="button" disabled>Shopify</button></li>
  </ul>

  <TextLinkTop />
</Layout>

<style lang="scss">
  .works {
    &__nav {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(auto, calc(100% / 4 - 20px * 3 / 4)));
      grid-template-rows: 50px;
      gap: 20px;
    }

    &__item {
      display: flex;
      justify-content: center;
      align-items: center;
      width: 100%;
      height: 100%;
      background-color: #dfdfdf;
      transition: color .3s, background-color .3s;

      &[disabled] {
        pointer-events: none;
        text-decoration: line-through;
      }

      &:not([disabled]) {
        &:hover {
          color: #fff;
          background-color: #000;
          cursor: pointer;
        }
      }
    }
  }
</style>
